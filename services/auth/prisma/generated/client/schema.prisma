generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL") 
}

model User {
  // Used String/UUID for better security in microservices to prevent IDOR attack :3
  id       String @id @default(uuid())
  email    String @unique
  username String @unique

  // Optional password for OAuth users
  password String?
  role     Role    @default(CLIENT)
  avatar   String  @default("/avatars/default.png")

  // Presence state
  isOnline Boolean @default(false)

  // Security & 2FA
  twoFASecret  String?
  twoFAEnabled Boolean @default(false)

  // OAuth fields
  oauthProvider String?
  oauthId       String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Ensures a unique combination of provider + ID
  @@unique([oauthProvider, oauthId])
}

enum Role {
  FREELANCER
  CLIENT
  ADMIN
}
